# Recall (from https://dashboard.recall.ai)
RECALL_API_KEY=
RECALL_REGION=us-west-2
RECALL_WEBHOOK_SECRET=

# Anthropic (from https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Public URL where Recall can reach our webhook receiver.
# Local dev: cloudflared tunnel URL + /webhook/recall
# Prod:      https://<railway-api-domain>/webhook/recall
WEBHOOK_PUBLIC_URL=http://localhost:8000/webhook/recall

# Infra (local dev; Railway injects these in prod via plugin references)
DATABASE_URL=postgresql://postgres:postgres@localhost:55432/recall
REDIS_URL=redis://localhost:56379
